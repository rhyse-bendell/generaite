# --- Private study data (inputs + derived analysis-ready datasets) ---
# Scripts read/write under Data/ (capital D) and may also use data/ on some machines.
Data/**
data/**

# Keep folder placeholders only
!Data/
!Data/**/
!data/
!data/**/
!Data/.gitkeep
!Data/**/.gitkeep
!data/.gitkeep
!data/**/.gitkeep

# --- Generated analysis outputs ---
# Scripts write run-stamped outputs under Results/Study*/run_*.
Results/**
results/**
outputs/
Outputs/
reports/generated/
tmp/
temp/
cache/
caches/
logs/

# Keep result folder placeholders only
!Results/
!Results/**/
!results/
!results/**/
!Results/.gitkeep
!Results/**/.gitkeep
!results/.gitkeep
!results/**/.gitkeep

# Common generated files
*.log
*.tmp

# --- Python ---
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.venv/
venv/
env/

# --- Local env / secrets ---
.env
.env.*
*.local

# --- Editor / OS ---
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
